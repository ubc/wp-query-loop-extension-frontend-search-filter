{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ctlt/query-search-filter",
	"version": "0.1.0",
	"title": "Query Filter - Search",
	"category": "widgets",
	"icon": "filter",
	"description": "Add search to the WP Query block.",
	"example": {},
	"supports": {
		"interactivity": true
	},
	"attributes": {
		"accessibleLabel": {
            "type": "string",
			"default": ""
        },
		"label": {
            "type": "string",
			"default": "Search"
        },
		"instanceId": {
            "type": "number",
			"default": null
        }
    },
	"usesContext": [
		"queryId"
	],
	"textdomain": "query-search-filter",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js"
}
